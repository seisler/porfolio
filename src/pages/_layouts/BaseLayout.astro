---
// Global page shell shared by every route (ADR-0004: layouts live in the
// `pages` layer, under the route-excluded `_layouts` folder, so they can
// compose `widgets` without breaking the shared → widgets import ban).
// Renders the terminal chrome — nav, name banner, and the intro block —
// with each route's content slotted in below the prompt.
// CSS-first, zero client-side JS (ADR-0002); tokens only (ADR-0003).
import '../../shared/tokens/tokens.css';
import Header from '../../widgets/header/Header.astro';
import NameBanner from '../../widgets/name-banner/NameBanner.astro';
import Footer from '../../widgets/footer/Footer.astro';

interface Props {
	title?: string;
}

const { title = 'Mark Schenzle' } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<Header />
		<main class="layout">
			<header class="layout__intro">
				<NameBanner>
					<p class="layout__welcome">Welcome to Mark's Terminal Portfolio</p>
				</NameBanner>
				<p class="layout__hint">
					Type '?' or 'help' to view a list of available commands.
				</p>
				<p class="layout__prompt">visitor@markschenzle.me:~$</p>
			</header>
			<div class="layout__content">
				<slot />
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	body {
		display: flex;
		flex-direction: column;
		min-height: 100dvh;
		margin: 0;
		background-color: var(--color-background);
		color: var(--color-text);
	}

	.layout {
		display: flex;
		flex: 1;
		flex-direction: column;
		padding: var(--space-4);
		padding-left: var(--space-7);
	}

	.layout__intro {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
	}

	.layout__welcome {
		margin: 0;
		font-family: var(--font-family-mono);
		font-size: var(--font-size-md);
		color: var(--color-text);
	}

	/* Two blank lines of separation between the welcome line and the hint. */
	.layout__hint {
		margin: var(--space-6) 0 0;
		font-family: var(--font-family-mono);
		font-size: var(--font-size-sm);
		color: var(--color-text-muted);
	}

	.layout__prompt {
		margin: var(--space-4) 0 0;
		font-family: var(--font-family-mono);
		font-size: var(--font-size-sm);
		color: var(--color-accent);
	}

	.layout__content {
		flex: 1;
	}
</style>
